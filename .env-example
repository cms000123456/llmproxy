# LLM Proxy Configuration Example
# Copy this file to .env and fill in your real values.

# -----------------------------------------------------------------------------
# Upstream API (required)
# -----------------------------------------------------------------------------
# The base URL of the upstream OpenAI-compatible API.
# For Kimi Code: https://api.kimi.com/coding/v1
# For Moonshot Open Platform: https://api.moonshot.cn/v1
LLM_PROXY_UPSTREAM_BASE_URL=https://api.moonshot.cn/v1

# Your API key for the upstream provider.
LLM_PROXY_UPSTREAM_API_KEY=your-api-key-here

# -----------------------------------------------------------------------------
# Authentication (optional but recommended)
# -----------------------------------------------------------------------------
# API keys for clients connecting to the proxy.
# Format: JSON array of strings
# Generate keys with: python -c "from llmproxy.auth import generate_api_key; print(generate_api_key())"
# LLM_PROXY_API_KEYS=["llmproxy_abc123...", "llmproxy_xyz789..."]

# Enable/disable API key authentication (default: true)
# When false, proxy operates in open mode (anyone can connect)
# When true and api_keys is empty, proxy also operates in open mode
LLM_PROXY_AUTH_ENABLED=true

# -----------------------------------------------------------------------------
# Proxy Server
# -----------------------------------------------------------------------------
LLM_PROXY_HOST=0.0.0.0
LLM_PROXY_PORT=8080

# -----------------------------------------------------------------------------
# Request Filtering
# -----------------------------------------------------------------------------
LLM_PROXY_ENABLE_FILTERING=true
LLM_PROXY_MAX_MESSAGE_LENGTH=32000
LLM_PROXY_STRIP_BASE64_IMAGES=false
LLM_PROXY_DEDUPLICATE_SYSTEM_MESSAGES=true
LLM_PROXY_REMOVE_EMPTY_MESSAGES=true

# -----------------------------------------------------------------------------
# Prompt Compression
# -----------------------------------------------------------------------------
LLM_PROXY_ENABLE_COMPRESSION=true
LLM_PROXY_COMPRESSION_STRATEGY=truncate_oldest
LLM_PROXY_MAX_TOTAL_TOKENS=120000
LLM_PROXY_SUMMARY_MODEL=moonshot-v1-8k

# -----------------------------------------------------------------------------
# Ollama Local LLM (optional)
# -----------------------------------------------------------------------------
# Ollama base URL - default is local instance
LLM_PROXY_OLLAMA_BASE_URL=http://localhost:11434

# Optional: API key for Ollama (only needed if Ollama is behind an auth proxy)
# Default local Ollama instances do not require authentication
# LLM_PROXY_OLLAMA_API_KEY=your-ollama-api-key

# Model to use for local processing
LLM_PROXY_OLLAMA_MODEL=llama3.2

# Enable Ollama for context compression (summarizes old messages)
LLM_PROXY_OLLAMA_ENABLE_COMPRESSION=true

# Enable Ollama for relevance filtering (scores messages against query)
LLM_PROXY_OLLAMA_ENABLE_RELEVANCE_FILTER=false

# Relevance threshold (0-1) - messages below this score are dropped
LLM_PROXY_OLLAMA_RELEVANCE_THRESHOLD=0.5

# -----------------------------------------------------------------------------
# Caching
# -----------------------------------------------------------------------------
LLM_PROXY_ENABLE_CACHE=true
LLM_PROXY_CACHE_TTL_SECONDS=300
LLM_PROXY_CACHE_MAX_SIZE=1000

# -----------------------------------------------------------------------------
# Kimi Code Compatibility
# -----------------------------------------------------------------------------
# Set to true if you are proxying to api.kimi.com/coding/v1 with a Kimi Code key.
# This injects the required agent headers (User-Agent, X-Msh-Platform, etc.).
LLM_PROXY_KIMI_CODE_COMPAT=false
LLM_PROXY_KIMI_CODE_VERSION=1.0.0
LLM_PROXY_KIMI_CODE_DEVICE_NAME=kimi-proxy
LLM_PROXY_KIMI_CODE_DEVICE_ID=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LLM_PROXY_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Agent CLI
# -----------------------------------------------------------------------------
# Maximum number of tool call rounds before the agent gives up.
# Increase this if the agent frequently hits the limit on complex tasks.
# Default: 10
# LLM_AGENT_MAX_TOOL_ROUNDS=30
